{
  "manifest_version": 2,
  "name": "AI Chat Sidebar",
  "version": "1.0.5",
  "description": "Open AI chat websites in Firefox sidebar with customizable list",
  "permissions": [
    "storage",
    "contextMenus",
    "notifications",
    "tabs",
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "browser_action": {
    "default_title": "AI Chat Sidebar",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "sidebar_action": {
    "default_title": "AI Chat Sidebar",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    },
    "default_panel": "sidebar.html",
    "open_at_install": false
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-chat-sidebar@ywhome.top",
      "strict_min_version": "59.0"
    }
  },
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  }
}
