{
  "manifest_version": 3,
  "name": "AI Chat Sidebar",
  "version": "1.0.0",
  "description": "Open AI chat websites in Edge sidebar with customizable list",
  "permissions": [
    "sidePanel",
    "storage",
    "contextMenus",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open AI Chat Sidebar",
    "default_icon": {
      "16": "icons/icon16.svg",
      "48": "icons/icon48.svg",
      "128": "icons/icon128.svg"
    }
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
